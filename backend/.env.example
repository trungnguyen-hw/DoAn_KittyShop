PORT=5000
NODE_ENV=development

# Database Connection (Use EITHER DATABASE_URL OR the separate DB_* variables below)
DATABASE_URL=mysql://user:password@host:port/database

# Separate Database Connection Parameters (Fallback if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kidty_shop

# SSL Database Config (For TiDB, PlanetScale, Aiven, or AWS RDS on Production)
# - DB_CA_CERT: Path or Raw contents of the CA certificate.
# - DB_SSL: Set to 'true' to force SSL connection. On production, SSL is enabled automatically for remote hosts.
# - DB_SSL_REJECT_UNAUTHORIZED: Set to 'false' if database SSL uses self-signed certificates.
DB_CA_CERT=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT Configuration
JWT_SECRET=replace-with-a-long-random-secret

# Initial Admin Seeding (Seeks to seed an admin user on startup/first login if the table is empty)
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-a-strong-password

# Allowed CORS origins (comma-separated, e.g. https://kidty-shop-frontend.vercel.app,http://localhost:5173)
FRONTEND_URL=http://localhost:5173
